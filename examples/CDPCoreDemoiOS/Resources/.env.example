# CDP Project Configuration
CDP_PROJECT_ID=your-project-id-here

# Set to "true" for offline mock mode (no real API calls)
CDP_USE_MOCK=true

# Optional: Override API base path
# CDP_BASE_PATH=https://api.developer.coinbase.com

# Account creation on login
# CDP_ETHEREUM_CREATE_ON_LOGIN=smart  # "smart" or "eoa"
# CDP_SOLANA_CREATE_ON_LOGIN=true

# OAuth callback URL scheme. Must match the CFBundleURLSchemes entry in
# the iOS app's Info.plist (default: "cdpdemo").
# CDP_CALLBACK_URL_SCHEME=cdpdemo
